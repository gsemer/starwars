# Copy this file to `.env` and adjust values as needed.

# General
APP_NAME="SWAPI Explorer API"
API_V1_PREFIX=/api/v1

# Database (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://swapi:swapi@localhost:5432/swapi
DB_ECHO=false

# SWAPI
SWAPI_BASE_URL=https://swapi.dev/api
SWAPI_TIMEOUT_SECONDS=10.0
SWAPI_MAX_RETRIES=3
SWAPI_BACKOFF_BASE_SECONDS=0.5

# Import batching
IMPORT_BATCH_SIZE=50

# Logging
LOG_LEVEL=INFO

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
