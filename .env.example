# Copy this file to `.env` and adjust values as needed.

# General
APP_NAME="SWAPI Explorer API"
API_V1_PREFIX=/api/v1

# Database (asyncpg driver required)
# Port 5433 matches the Postgres service in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://swapi:swapi@localhost:5433/swapi
DB_ECHO=false

# Redis
# Port 6381 matches the Redis service in docker-compose.yml
REDIS_URL=redis://localhost:6381/0
IMPORT_LOCK_TTL_SECONDS=300

# SWAPI
SWAPI_BASE_URL=https://swapi.dev/api
SWAPI_TIMEOUT_SECONDS=10.0
SWAPI_MAX_RETRIES=3
SWAPI_BACKOFF_BASE_SECONDS=0.5

# Import batching
IMPORT_BATCH_SIZE=50

# Max concurrent outbound SWAPI requests per worker
MAX_CONCURRENCY=1

# Logging
LOG_LEVEL=INFO

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100